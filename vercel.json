{
  "version": 2,
  "name": "veritas-landing-page",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "hero-image.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/hero-image.png",
      "dest": "/hero-image.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
